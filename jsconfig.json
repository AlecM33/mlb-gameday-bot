{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "spec/data/**"
  ]
}

