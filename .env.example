DB_USER=postgres
DB_PASSWORD=yourpassword
NODE_ENV=production
DB_NAME=postgres
DB_PORT=5432
DISCORD_TOKEN=yourtoken
TEAM_ID=114
LOG_LEVEL=trace
DISCORD_CLIENT_ID=yourclientid
# Set REQUIRE_SSL=true for remote or managed database instances.
# Not needed when the database is running locally or in the same Docker network.
REQUIRE_SSL=false
# Required when REQUIRE_SSL=true — paste the full PEM content including the -----BEGIN CERTIFICATE----- and -----END CERTIFICATE----- lines.
# The value contains newlines, so it must be wrapped in double quotes.
DB_SSL_CA=
TIME_ZONE=America/New_York
LOCALE=en-US
# Optional: healthchecks.io uptime monitoring. Leave HC_PING_URL unset to disable.
HC_PING_URL=
HC_PING_INTERVAL_MS=600000

